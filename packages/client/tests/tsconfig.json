{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": "..",
    "types": ["vite/client", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
