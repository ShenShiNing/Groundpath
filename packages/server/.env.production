# ==================== Server ====================
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-domain.com

# Proxy Settings (required when behind nginx/cloudflare)
TRUST_PROXY=true

# ==================== Database ====================
DATABASE_URL="mysql://username:password@localhost:3306/knowledge-agent"
# DB_CONNECTION_LIMIT=10

# ==================== Authentication ====================
# REQUIRED: Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# ==================== Email (SMTP) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=
EMAIL_VERIFICATION_SECRET=

# ==================== OAuth Providers ====================
# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-domain.com/api/auth/oauth/github/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/oauth/google/callback

# ==================== Storage ====================
STORAGE_TYPE=r2

# Cloudflare R2 Storage (required for production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# File Signing (optional, defaults to ENCRYPTION_KEY)
# FILE_SIGNING_SECRET=

# ==================== Document Processing ====================
MAX_DOCUMENT_SIZE=22020096

# ==================== Embedding Providers ====================
EMBEDDING_PROVIDER=zhipu
ZHIPU_API_KEY=

# Alternative providers (uncomment as needed)
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ==================== Vector Database (Qdrant) ====================
QDRANT_URL=
QDRANT_API_KEY=

# ==================== LLM Providers ====================
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== Logging ====================
LOG_LEVEL=info
LOG_CLEANUP_ENABLED=true

# ==================== Feature Flags ====================
DISABLE_RATE_LIMIT=false
# COUNTER_SYNC_ENABLED=false
