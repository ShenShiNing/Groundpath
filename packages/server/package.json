{
  "name": "@groundpath/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/index.ts",
    "db:migrate:prod": "tsx src/scripts/db-migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:drift-check": "tsx src/scripts/db-drift-check.ts",
    "db:migrate": "tsx src/scripts/db-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:sync-counters": "tsx src/scripts/sync-counters.ts",
    "db:check": "tsx src/scripts/db-consistency-check.ts",
    "db:verify": "pnpm run db:drift-check && pnpm run db:check",
    "document-index:backfill": "tsx src/scripts/document-index-backfill.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
