    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@types/pdf-parse": "^1.1.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ua-parser-js": "^0.7.39",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.29",
