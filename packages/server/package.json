    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "openai": "^6.17.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "ua-parser-js": "^2.0.8",
    "uuid": "^13.0.0"
