    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@aws-sdk/client-s3": "^3.978.0",
    "@groundpath/shared": "workspace:*",
    "@qdrant/js-client-rest": "^1.16.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
