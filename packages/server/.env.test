# Server Configuration
NODE_ENV=test
PORT=3001

# Database Configuration (use separate test database!)
DATABASE_URL="mysql://root:password@localhost:3306/knowledge-agent-test"

# JWT Configuration
JWT_ACCESS_SECRET=test-access-secret
JWT_REFRESH_SECRET=test-refresh-secret

# SMTP Configuration (disabled for tests)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Knowledge Agent Test
EMAIL_FROM_ADDRESS=test@example.com

# Email Verification Token Secret
EMAIL_VERIFICATION_SECRET=test-verification-secret

# GitHub OAuth
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/oauth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/oauth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Cloudflare R2 Storage (use mocks in tests)
R2_ACCOUNT_ID=test-account-id
R2_ACCESS_KEY_ID=test-access-key
R2_SECRET_ACCESS_KEY=test-secret-key
R2_BUCKET_NAME=test-bucket
R2_PUBLIC_URL=https://test-bucket.example.com

# Document upload (21 MiB)
MAX_DOCUMENT_SIZE=22020096

# Rate limiting (disabled for tests)
DISABLE_RATE_LIMIT=true

# Logging (silent for cleaner test output)
LOG_LEVEL=silent
