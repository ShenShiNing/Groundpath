# ==================== Server ====================
NODE_ENV=test
PORT=3001
FRONTEND_URL=http://localhost:5173

# ==================== Database ====================
# Use separate test database!
DATABASE_URL="mysql://root:password@localhost:3306/knowledge-agent-test"

# ==================== Authentication ====================
JWT_ACCESS_SECRET=test-access-secret-must-be-at-least-32-chars
JWT_REFRESH_SECRET=test-refresh-secret-must-be-at-least-32-chars
ENCRYPTION_KEY=test-encryption-key-must-be-at-least-32-chars

# ==================== Email (SMTP) ====================
# Disabled for tests - leave SMTP_HOST empty
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Knowledge Agent Test
EMAIL_FROM_ADDRESS=test@example.com
EMAIL_VERIFICATION_SECRET=test-verification-secret-32chars!

# ==================== OAuth Providers ====================
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/oauth/github/callback

GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/oauth/google/callback

# ==================== Storage ====================
# Use local storage for tests
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads-test

# R2 credentials (use mocks in tests)
R2_ACCOUNT_ID=test-account-id
R2_ACCESS_KEY_ID=test-access-key
R2_SECRET_ACCESS_KEY=test-secret-key
R2_BUCKET_NAME=test-bucket
R2_PUBLIC_URL=https://test-bucket.example.com

# Disable file signing for simpler test setup
DISABLE_FILE_SIGNING=true

# ==================== Document Processing ====================
MAX_DOCUMENT_SIZE=22020096

# ==================== Embedding Providers ====================
EMBEDDING_PROVIDER=zhipu
ZHIPU_API_KEY=test-zhipu-api-key

# ==================== Vector Database (Qdrant) ====================
QDRANT_URL=http://localhost:6333

# ==================== LLM Providers ====================
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== Logging ====================
# Silent for cleaner test output
LOG_LEVEL=silent
LOG_CLEANUP_ENABLED=false

# ==================== Feature Flags ====================
# Disable rate limiting for tests
DISABLE_RATE_LIMIT=true
COUNTER_SYNC_ENABLED=false
