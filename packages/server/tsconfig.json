{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],

    // Path aliases to reduce deep relative imports
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@modules/*": ["src/modules/*"],
      "@config/*": ["src/core/config/*"],
      "@tests/*": ["tests/*"]
    },

    // Stricter checks for server code
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    // Not needed for server
    "jsx": "preserve"
  },
  "include": ["src", "tests"]
}
