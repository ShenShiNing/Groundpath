# ==================== Server ====================
NODE_ENV=development
PORT=3000
# SERVER_TIMEOUT=30000
# SERVER_KEEP_ALIVE_TIMEOUT=65000
# SHUTDOWN_TIMEOUT=10000
FRONTEND_URL=http://localhost:5173

# Proxy Settings (for correct client IP detection behind reverse proxy)
# Set when behind nginx, cloudflare, or other reverse proxy
# Values: 'true' (trust all), '1' (trust first proxy), 'loopback', or specific IPs
# IMPORTANT: Required for correct rate limiting and audit logs when proxied
# TRUST_PROXY=true

# ==================== Database ====================
DATABASE_URL="mysql://username:password@localhost:3306/your-database"
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0

# ==================== Authentication ====================
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
# Optional JWT key rotation settings
# JWT_ACCESS_KEY_ID=access-v1
# JWT_REFRESH_KEY_ID=refresh-v1
# JWT_ACCESS_PREVIOUS_SECRETS=old-access-secret-1,old-access-secret-2
# JWT_REFRESH_PREVIOUS_SECRETS=old-refresh-secret-1,old-refresh-secret-2
# JWT_ISSUER=knowledge-agent
# JWT_AUDIENCE=knowledge-agent-client
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Token expiration (in seconds)
# ACCESS_TOKEN_EXPIRES_IN=900        # 15 minutes
# REFRESH_TOKEN_EXPIRES_IN=604800    # 7 days

# Password hashing
# BCRYPT_SALT_ROUNDS=12              # 4-31, higher = more secure but slower

# ==================== Email (SMTP) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=noreply@example.com

# Email Verification
# Must be at least 1 character
EMAIL_VERIFICATION_SECRET=your-verification-secret-change-in-production
# EMAIL_CODE_LENGTH=6                           # 4-10 digits
# EMAIL_CODE_EXPIRES_MINUTES=10
# EMAIL_RESEND_COOLDOWN_SECONDS=60
# EMAIL_MAX_CODES_PER_HOUR=5
# EMAIL_VERIFICATION_TOKEN_EXPIRES_MINUTES=5

# ==================== OAuth Providers ====================
# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback
# OAUTH_STATE_SECRET=your-oauth-state-secret-optional

# ==================== Storage ====================
# STORAGE_TYPE: 'local' or 'r2'
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# Cloudflare R2 Storage (required when STORAGE_TYPE=r2)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-bucket.your-domain.com

# File Signing (for secure file access)
# FILE_SIGNING_SECRET: defaults to ENCRYPTION_KEY if not set. Must be at least 32 characters.
# FILE_SIGNING_SECRET=your-32-character-signing-secret
# FILE_URL_EXPIRES_IN=3600           # Document URL expiration in seconds (default: 1 hour)
# AVATAR_URL_EXPIRES_IN=604800       # Avatar URL expiration in seconds (default: 7 days)
# DISABLE_FILE_SIGNING=false         # Set to 'true' to disable (NOT recommended for production)

# ==================== Document Processing ====================
# MAX_DOCUMENT_SIZE=22020096         # Max upload size in bytes (default: 21 MiB)
# TEXT_CONTENT_MAX_LENGTH=500000     # Max chars for editable files (markdown/text)
# TEXT_PREVIEW_MAX_LENGTH=50000      # Max chars for preview-only files (pdf/docx)
# CHUNK_SIZE=512                     # Text chunk size for embeddings
# CHUNK_OVERLAP=50                   # Overlap between chunks

# ==================== Embedding Providers ====================
# EMBEDDING_PROVIDER: 'zhipu', 'openai', or 'ollama'
EMBEDDING_PROVIDER=zhipu
# EMBEDDING_CONCURRENCY=5

# Zhipu AI (default provider)
ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_EMBEDDING_MODEL=embedding-3
# ZHIPU_EMBEDDING_DIMENSIONS=1024

# OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==================== Vector Database (Qdrant) ====================
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key

# ==================== LLM Providers ====================
# Used as fallback when user hasn't configured their own
# ANTHROPIC_API_KEY=your-anthropic-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== Logging ====================
# LOG_LEVEL: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# Log Retention (days)
# LOG_RETENTION_LOGIN_DAYS=90
# LOG_RETENTION_OPERATION_DAYS=365
# LOG_RETENTION_SYSTEM_DAYS=30

# Log Cleanup
# LOG_CLEANUP_BATCH_SIZE=1000
# LOG_CLEANUP_ENABLED=true

# ==================== Feature Flags ====================
# DISABLE_RATE_LIMIT=false           # Set to 'true' for development
# COUNTER_SYNC_ENABLED=false         # Enable periodic counter sync
