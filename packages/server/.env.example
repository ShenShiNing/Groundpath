# ==================== Server ====================
NODE_ENV=development
PORT=3000
# SERVER_TIMEOUT=30000
# SERVER_KEEP_ALIVE_TIMEOUT=65000
# SHUTDOWN_TIMEOUT=10000
FRONTEND_URL=http://localhost:5173

# Proxy Settings (for correct client IP detection behind reverse proxy)
# Set when behind nginx, cloudflare, or other reverse proxy
# Values: 'true' (trust all), '1' (trust first proxy), 'loopback', or specific IPs
# IMPORTANT: Required for correct rate limiting and audit logs when proxied
# TRUST_PROXY=true

# ==================== Database ====================
DATABASE_URL="mysql://username:password@localhost:3306/your-database"
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0
# MySQL session timezone for mysql2 driver date conversion (e.g. '+08:00', '+00:00')
# Must match your MySQL server's @@session.time_zone to avoid TIMESTAMP misinterpretation.
# Default: '+00:00' (UTC). Run `SELECT @@session.time_zone` in MySQL to check.
# DB_TIMEZONE=+00:00

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379
# If Redis requires auth:
# REDIS_URL=redis://:your-password@localhost:6379
# REDIS_URL=redis://your-username:your-password@localhost:6379
# REDIS_PREFIX=knowledge-agent

# ==================== Authentication ====================
# JWT secret for HS256 signing (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
# JWT_ISSUER=knowledge-agent
# JWT_AUDIENCE=knowledge-agent-client
ENCRYPTION_KEY=your-32-character-encryption-key-here
# Optional: dedicated hashing secret for OAuth exchange code storage
# OAUTH_EXCHANGE_CODE_SECRET=your-32-character-oauth-exchange-hash-secret
# AUTH_COOKIE_SAMESITE=strict        # strict | lax | none
# AUTH_COOKIE_DOMAIN=                # Optional, e.g. .example.com

# ==================== Email (SMTP) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=noreply@example.com

# Email Verification
# Must be at least 1 character
EMAIL_VERIFICATION_SECRET=your-verification-secret-change-in-production

# ==================== OAuth Providers ====================
# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ==================== Storage ====================
# STORAGE_TYPE: 'local' or 'r2'
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# Cloudflare R2 Storage (required when STORAGE_TYPE=r2)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-bucket.your-domain.com

# File Signing (for secure file access)
# FILE_SIGNING_SECRET: defaults to ENCRYPTION_KEY if not set. Must be at least 32 characters.
# FILE_SIGNING_SECRET=your-32-character-signing-secret
# DISABLE_FILE_SIGNING=false         # Set to 'true' to disable (NOT recommended for production)

# ==================== Embedding Providers ====================
# EMBEDDING_PROVIDER: 'zhipu', 'openai', or 'ollama'
EMBEDDING_PROVIDER=zhipu
# EMBEDDING_CONCURRENCY=5

# Zhipu AI (default provider)
ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_EMBEDDING_MODEL=embedding-3
# ZHIPU_EMBEDDING_DIMENSIONS=1024

# OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==================== Vector Database (Qdrant) ====================
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key

# ==================== LLM Providers ====================
# LLM API keys and base URLs are configured per-user via the frontend AI Settings page.
# MODEL_FETCH_TIMEOUT=15000

# ==================== Agent / Web Search ====================
# TAVILY_API_KEY=tvly-xxxxx

# ==================== VLM (Vision Language Model) ====================
# Used for generating text descriptions of images extracted from PDF documents.
# Requires IMAGE_DESCRIPTION_ENABLED=true in Feature Flags.
# VLM_PROVIDER=openai                    # openai | anthropic
# VLM_MODEL=gpt-4o-mini                  # Model with vision capability
# VLM_API_KEY=                            # Required when IMAGE_DESCRIPTION_ENABLED=true
# VLM_BASE_URL=                           # Optional custom base URL

# ==================== Queue / Worker ====================
# QUEUE_CONCURRENCY=3             # Max concurrent document processing jobs

# ==================== Logging ====================
# LOG_LEVEL: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# ==================== Structured RAG Observability ====================
# STRUCTURED_RAG_ALERTS_ENABLED=false
# STRUCTURED_RAG_ALERT_EMAIL_TO=ops@example.com,owner@example.com
# STRUCTURED_RAG_ALERT_SCHEDULE_CRON=0 5 * * *

# ==================== Schedules (Cron, UTC) ====================
# DOCUMENT_PROCESSING_RECOVERY_CRON=*/10 * * * *
# DOCUMENT_BUILD_CLEANUP_CRON=30 3 * * *
# BACKFILL_SCHEDULE_CRON=0 2 * * *

# ==================== Feature Flags ====================
# DISABLE_RATE_LIMIT=false           # Set to 'true' for development
# COUNTER_SYNC_ENABLED=false         # Enable periodic counter sync
# STRUCTURED_RAG_ENABLED=false       # Master switch for structured RAG routing
# STRUCTURED_RAG_ROLLOUT_MODE=disabled   # disabled | internal | all
# STRUCTURED_RAG_INTERNAL_USER_IDS=       # Comma-separated allowlist used when rollout mode is internal
# STRUCTURED_RAG_INTERNAL_KB_IDS=         # Comma-separated KB allowlist used when rollout mode is internal
# IMAGE_DESCRIPTION_ENABLED=false         # Enable VLM image description for figure nodes in structured RAG
# DOCUMENT_PROCESSING_RECOVERY_ENABLED=true   # Enable periodic recovery of stale processing status
# DOCUMENT_PROCESSING_RECOVERY_REQUEUE_ENABLED=true   # Re-enqueue recovered stale documents immediately
# DOCUMENT_BUILD_CLEANUP_ENABLED=true         # Enable cleanup of superseded/failed immutable builds
# DOCUMENT_BUILD_CLEANUP_RETENTION_DAYS=7     # Keep immutable build artifacts for at least N days
# DOCUMENT_BUILD_CLEANUP_BATCH_SIZE=100       # Max immutable builds cleaned per run
# LOG_CLEANUP_ENABLED=true                    # Enable scheduled log retention cleanup
# BACKFILL_SCHEDULE_ENABLED=false             # Enable scheduled backfill batches
