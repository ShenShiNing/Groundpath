# Server Configuration
PORT=3000
NODE_ENV=development

# DataBase Configuration
DATABASE_URL="mysql://username:password@localhost:3306/your-database"

# JWT Authentication
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# SMTP Configuration (for email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=noreply@example.com

# Email Verification Token Secret
EMAIL_VERIFICATION_SECRET=your-verification-secret-change-in-production

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Cloudflare R2 Storage (for avatar uploads)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# Storage Configuration
# STORAGE_TYPE: 'local' or 'r2' (defaults to 'local' for dev, 'r2' for production)
STORAGE_TYPE=local
# LOCAL_STORAGE_PATH: directory for local file storage (only used when STORAGE_TYPE=local)
LOCAL_STORAGE_PATH=./uploads

# Document Upload
# MAX_DOCUMENT_SIZE: maximum document size in bytes (default: 22020096 = 21 MiB)
MAX_DOCUMENT_SIZE=22020096

# Rate Limiting
# DISABLE_RATE_LIMIT: set to 'true' to disable rate limiting (useful for development)
DISABLE_RATE_LIMIT=false

# Logging
# LOG_LEVEL: fatal, error, warn, info, debug, trace, silent (default: info)
LOG_LEVEL=info

# Log Retention (days)
LOG_RETENTION_LOGIN_DAYS=90
LOG_RETENTION_OPERATION_DAYS=365
LOG_RETENTION_SYSTEM_DAYS=30

# Log Cleanup
# LOG_CLEANUP_BATCH_SIZE: number of records to delete per batch (default: 1000)
LOG_CLEANUP_BATCH_SIZE=1000
# LOG_CLEANUP_ENABLED: set to 'false' to disable scheduled log cleanup
LOG_CLEANUP_ENABLED=true

# Encryption (for storing user API keys securely)
# Must be at least 32 characters. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-character-encryption-key-here

# LLM Providers (optional - used as fallback when user hasn't configured their own)
# OPENAI_API_KEY is also used for embeddings if EMBEDDING_PROVIDER=openai
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com