# ==================== Server ====================
NODE_ENV=development
PORT=3000
# SERVER_TIMEOUT=30000
# SERVER_KEEP_ALIVE_TIMEOUT=65000
# SHUTDOWN_TIMEOUT=10000
FRONTEND_URL=http://localhost:5173

# Proxy Settings (for correct client IP detection behind reverse proxy)
# Set when behind nginx, cloudflare, or other reverse proxy
# Values: 'true' (trust all), '1' (trust first proxy), 'loopback', or specific IPs
# IMPORTANT: Required for correct rate limiting and audit logs when proxied
# TRUST_PROXY=true

# ==================== Database ====================
DATABASE_URL="mysql://username:password@localhost:3306/your-database"
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379
# If Redis requires auth:
# REDIS_URL=redis://:your-password@localhost:6379
# REDIS_URL=redis://your-username:your-password@localhost:6379
# REDIS_PREFIX=knowledge-agent

# ==================== Authentication ====================
# JWT secret for HS256 signing (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
# JWT_ISSUER=knowledge-agent
# JWT_AUDIENCE=knowledge-agent-client
ENCRYPTION_KEY=your-32-character-encryption-key-here
# Optional: dedicated hashing secret for OAuth exchange code storage
# OAUTH_EXCHANGE_CODE_SECRET=your-32-character-oauth-exchange-hash-secret

# Token expiration (in seconds)
# ACCESS_TOKEN_EXPIRES_IN=900        # 15 minutes
# REFRESH_TOKEN_EXPIRES_IN=604800    # 7 days

# Password hashing
# BCRYPT_SALT_ROUNDS=12              # 4-31, higher = more secure but slower
# AUTH_COOKIE_SAMESITE=strict        # strict | lax | none
# AUTH_COOKIE_DOMAIN=                # Optional, e.g. .example.com

# ==================== Email (SMTP) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=noreply@example.com

# Email Verification
# Must be at least 1 character
EMAIL_VERIFICATION_SECRET=your-verification-secret-change-in-production
# EMAIL_CODE_LENGTH=6                           # 4-10 digits
# EMAIL_CODE_EXPIRES_MINUTES=10
# EMAIL_RESEND_COOLDOWN_SECONDS=60
# EMAIL_MAX_CODES_PER_HOUR=5
# EMAIL_VERIFICATION_TOKEN_EXPIRES_MINUTES=5

# ==================== OAuth Providers ====================
# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ==================== Storage ====================
# STORAGE_TYPE: 'local' or 'r2'
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# Cloudflare R2 Storage (required when STORAGE_TYPE=r2)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-bucket.your-domain.com

# File Signing (for secure file access)
# FILE_SIGNING_SECRET: defaults to ENCRYPTION_KEY if not set. Must be at least 32 characters.
# FILE_SIGNING_SECRET=your-32-character-signing-secret
# FILE_URL_EXPIRES_IN=3600           # Document URL expiration in seconds (default: 1 hour)
# AVATAR_URL_EXPIRES_IN=604800       # Avatar URL expiration in seconds (default: 7 days)
# DISABLE_FILE_SIGNING=false         # Set to 'true' to disable (NOT recommended for production)

# ==================== Document Processing ====================
# MAX_DOCUMENT_SIZE=22020096         # Max upload size in bytes (default: 21 MiB)
# TEXT_CONTENT_MAX_LENGTH=500000     # Max chars for editable files (markdown/text)
# TEXT_PREVIEW_MAX_LENGTH=50000      # Max chars for preview-only files (pdf/docx)
# CHUNK_SIZE=512                     # Text chunk size for embeddings
# CHUNK_OVERLAP=50                   # Overlap between chunks
# VECTOR_BATCH_SIZE=20               # Batch size for vector embedding operations

# ==================== Document Index / Structured RAG ====================
# DOCUMENT_INDEX_ROUTE_TOKEN_THRESHOLD=5000  # Route to structured path when estimated tokens reach this threshold
# DOCUMENT_INDEX_CHARS_PER_TOKEN=4           # Rough char->token ratio used for route decisions
# DOCUMENT_INDEX_PDF_TIMEOUT=30000           # Max runtime per PDF parse attempt in ms (docling)
# DOCUMENT_INDEX_PDF_CONCURRENCY=2           # Max concurrent PDF parse jobs per server instance

# ==================== RAG Search Defaults ====================
# RAG_SEARCH_DEFAULT_LIMIT=5         # Default number of search results
# RAG_SEARCH_DEFAULT_SCORE_THRESHOLD=0.5  # Minimum relevance score (0-1)

# ==================== Document AI ====================
# DOCUMENT_AI_MAX_CONTEXT_TOKENS=8000         # Max tokens for summary context window
# DOCUMENT_AI_CHARS_PER_TOKEN=3               # Character-to-token ratio estimate
# DOCUMENT_AI_SUMMARY_BATCH_SIZE=5            # Batch size for hierarchical summarization
# DOCUMENT_AI_MAX_ANALYSIS_CHARS=30000        # Max chars sent to LLM for analysis
# DOCUMENT_AI_CACHE_TTL_MS=3600000            # Cache TTL in ms (default: 1 hour)
# DOCUMENT_AI_CACHE_CLEANUP_INTERVAL_MS=300000  # Cache cleanup interval in ms (default: 5 min)
# DOCUMENT_AI_HEARTBEAT_INTERVAL_MS=15000     # SSE heartbeat interval in ms

# ==================== Embedding Providers ====================
# EMBEDDING_PROVIDER: 'zhipu', 'openai', or 'ollama'
EMBEDDING_PROVIDER=zhipu
# EMBEDDING_CONCURRENCY=5

# Zhipu AI (default provider)
ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_EMBEDDING_MODEL=embedding-3
# ZHIPU_EMBEDDING_DIMENSIONS=1024

# OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==================== Vector Database (Qdrant) ====================
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key

# ==================== LLM Providers ====================
# Dedicated LLM API keys (separate from embedding keys)
# OPENAI_LLM_API_KEY=your-openai-llm-api-key
# ZHIPU_LLM_API_KEY=your-zhipu-llm-api-key
# OLLAMA_LLM_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=your-anthropic-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== Agent / Web Search ====================
# TAVILY_API_KEY=tvly-xxxxx
# AGENT_MAX_ITERATIONS=10
# AGENT_MAX_STRUCTURED_ROUNDS=3
# AGENT_MAX_FALLBACK_ROUNDS=1
# AGENT_TOOL_TIMEOUT=15000
# AGENT_MAX_NODE_READ_TOKENS=1200
# AGENT_REF_FOLLOW_MAX_DEPTH=3
# AGENT_REF_FOLLOW_MAX_NODES=20
# TAVILY_MAX_RESULTS=5
# TAVILY_CONTENT_MAX_LENGTH=2000

# Citation evidence selection
# AGENT_CITATION_OUTLINE_SCORE_CEILING=30   # Normalization ceiling for outline_search raw scores
# AGENT_CITATION_NODE_READ_BASE_SCORE=0.7   # Fixed normalized score for node_read citations
# AGENT_CITATION_REF_FOLLOW_BASE_SCORE=0.6  # Fixed normalized score for ref_follow citations
# AGENT_CITATION_MIN_DOCUMENTS=3            # Guaranteed document diversity slots
# AGENT_CITATION_MIN_SCORE=0.35             # Minimum normalized score to keep a citation
# AGENT_CITATION_PARENT_SCORE_ADVANTAGE=0.15 # Parent must beat child by this margin to win

# ==================== VLM (Vision Language Model) ====================
# Used for generating text descriptions of images extracted from PDF documents.
# Requires IMAGE_DESCRIPTION_ENABLED=true in Feature Flags.
# VLM_PROVIDER=openai                    # openai | anthropic
# VLM_MODEL=gpt-4o-mini                  # Model with vision capability
# VLM_API_KEY=                            # Falls back to OPENAI_LLM_API_KEY / ANTHROPIC_API_KEY
# VLM_BASE_URL=                           # Optional custom base URL
# VLM_TIMEOUT_MS=30000                    # Per-image timeout (5s–120s)
# VLM_CONCURRENCY=2                       # Max concurrent VLM calls (1–8)
# VLM_MAX_RETRIES=2                       # Retry count for 429/5xx (0–5)
# VLM_MAX_IMAGE_SIZE_BYTES=10485760       # Skip images larger than 10 MB
# VLM_MAX_TOKENS=1024                     # Max tokens per description (100–4096)

# ==================== Queue / Worker ====================
# QUEUE_CONCURRENCY=3             # Max concurrent document processing jobs
# QUEUE_MAX_RETRIES=3             # Retry attempts on failure
# QUEUE_BACKOFF_DELAY=5000        # Initial backoff delay in ms
# QUEUE_BACKOFF_TYPE=exponential  # fixed | exponential

# ==================== Backfill ====================
# BACKFILL_BATCH_SIZE=100         # Default number of documents scanned/enqueued per run
# BACKFILL_ENQUEUE_DELAY_MS=0     # Optional pause between backfill enqueue operations in ms

# ==================== Logging ====================
# LOG_LEVEL: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# Log Retention (days)
# LOG_RETENTION_LOGIN_DAYS=90
# LOG_RETENTION_OPERATION_DAYS=365
# LOG_RETENTION_SYSTEM_DAYS=30

# Log Cleanup
# LOG_CLEANUP_BATCH_SIZE=1000
# LOG_CLEANUP_ENABLED=true

# ==================== Structured RAG Observability ====================
# STRUCTURED_RAG_ALERTS_ENABLED=false
# STRUCTURED_RAG_ALERT_EMAIL_TO=ops@example.com,owner@example.com
# STRUCTURED_RAG_ALERT_WINDOW_HOURS=24
# STRUCTURED_RAG_ALERT_SCHEDULE_CRON=0 5 * * *
# STRUCTURED_RAG_ALERT_COOLDOWN_HOURS=6
# STRUCTURED_RAG_ALERT_REMINDER_HOURS=24
# STRUCTURED_RAG_ALERT_FALLBACK_RATIO_THRESHOLD=35
# STRUCTURED_RAG_ALERT_BUDGET_EXHAUSTION_THRESHOLD=10
# STRUCTURED_RAG_ALERT_PROVIDER_ERROR_THRESHOLD=3
# STRUCTURED_RAG_ALERT_FRESHNESS_LAG_MS_THRESHOLD=300000
# STRUCTURED_RAG_REPORT_DEFAULT_DAYS=30

# ==================== Feature Flags ====================
# DISABLE_RATE_LIMIT=false           # Set to 'true' for development
# COUNTER_SYNC_ENABLED=false         # Enable periodic counter sync
# STRUCTURED_RAG_ENABLED=false       # Master switch for structured RAG routing
# STRUCTURED_RAG_ROLLOUT_MODE=disabled   # disabled | internal | all
# STRUCTURED_RAG_INTERNAL_USER_IDS=       # Comma-separated allowlist used when rollout mode is internal
# STRUCTURED_RAG_INTERNAL_KB_IDS=         # Comma-separated KB allowlist used when rollout mode is internal
# IMAGE_DESCRIPTION_ENABLED=false         # Enable VLM image description for figure nodes in structured RAG
