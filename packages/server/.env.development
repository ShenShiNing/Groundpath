# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL="mysql://root:password@localhost:3306/knowledge-agent"

# JWT Configuration
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# SMTP Configuration (for email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=noreply@example.com

# Email Verification Token Secret
EMAIL_VERIFICATION_SECRET=dev-verification-secret-change-in-production

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback
FRONTEND_URL=http://localhost:5173/dashboard

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Storage Configuration
# STORAGE_TYPE: 'local' or 'r2' (defaults to 'local' for dev, 'r2' for production)
STORAGE_TYPE=local
# LOCAL_STORAGE_PATH: directory for local file storage (only used when STORAGE_TYPE=local)
LOCAL_STORAGE_PATH=./uploads

# Document upload (21 MiB)
MAX_DOCUMENT_SIZE=22020096

# Rate limiting (disabled for development)
DISABLE_RATE_LIMIT=true

# Embedding Provider (zhipu | openai | ollama)
EMBEDDING_PROVIDER=zhipu

# 智谱 API (default embedding provider)
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# OpenAI (alternative)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Logging
LOG_LEVEL=debug

# Log Retention (days)
LOG_RETENTION_LOGIN_DAYS=90
LOG_RETENTION_OPERATION_DAYS=365
LOG_RETENTION_SYSTEM_DAYS=30

# Log Cleanup
# LOG_CLEANUP_BATCH_SIZE: number of records to delete per batch (default: 1000)
LOG_CLEANUP_BATCH_SIZE=1000
# LOG_CLEANUP_ENABLED: set to 'false' to disable scheduled log cleanup
LOG_CLEANUP_ENABLED=true
