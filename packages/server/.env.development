# ==================== Server ====================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ==================== Database ====================
DATABASE_URL="mysql://root:password@localhost:3306/knowledge-agent"

# ==================== Authentication ====================
# Development secrets (change in production!)
JWT_ACCESS_SECRET=dev-access-secret-must-be-at-least-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-must-be-at-least-32-chars
ENCRYPTION_KEY=dev-encryption-key-must-be-32-chars!!

# ==================== Email (SMTP) ====================
# Configure for local email testing (e.g., Mailpit, MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Knowledge Agent
EMAIL_FROM_ADDRESS=noreply@localhost
EMAIL_VERIFICATION_SECRET=dev-verification-secret-32-chars!!

# ==================== OAuth Providers ====================
# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ==================== Storage ====================
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# Cloudflare R2 (optional for dev, configure in .env.development.local)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# File Signing (disabled for easier local development)
DISABLE_FILE_SIGNING=true

# ==================== Document Processing ====================
MAX_DOCUMENT_SIZE=22020096
# TEXT_CONTENT_MAX_LENGTH=500000
# TEXT_PREVIEW_MAX_LENGTH=50000
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== Embedding Providers ====================
EMBEDDING_PROVIDER=zhipu
# EMBEDDING_CONCURRENCY=5

# Zhipu AI (configure API key in .env.development.local)
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# OpenAI (alternative)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==================== Vector Database (Qdrant) ====================
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ==================== LLM Providers ====================
# Configure API keys in .env.development.local
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== Logging ====================
LOG_LEVEL=debug

# Log Retention (days)
LOG_RETENTION_LOGIN_DAYS=90
LOG_RETENTION_OPERATION_DAYS=365
LOG_RETENTION_SYSTEM_DAYS=30

# Log Cleanup
LOG_CLEANUP_BATCH_SIZE=1000
LOG_CLEANUP_ENABLED=true

# ==================== Feature Flags ====================
# Disable rate limiting for development
DISABLE_RATE_LIMIT=true
COUNTER_SYNC_ENABLED=false
