{
  "name": "knowledge-agent",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm -F @knowledge-agent/client dev",
    "dev:server": "pnpm -F @knowledge-agent/server dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:server": "pnpm -F @knowledge-agent/server test",
    "test:shared": "pnpm -F @knowledge-agent/shared test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --cache --cache-location .cache/eslint/.eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint/.eslintcache",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache --cache-location .cache/eslint/.eslintcache",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tanstack/eslint-plugin-query": "^5.91.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
