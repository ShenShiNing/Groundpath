# Copy to deploy/blue-green/shared.env on the server.
# This file is sourced by bash and consumed by docker compose.

# GHCR image naming. The deploy script will build:
#   ghcr.io/<namespace>/<repository>-server:<DEPLOY_IMAGE_TAG>
#   ghcr.io/<namespace>/<repository>-client:<DEPLOY_IMAGE_TAG>
GHCR_NAMESPACE=your-github-owner
GHCR_REPOSITORY=groundpath

# Optional overrides if your image names do not follow the default pattern.
# SERVER_IMAGE_REPOSITORY=ghcr.io/your-github-owner/groundpath-server
# CLIENT_IMAGE_REPOSITORY=ghcr.io/your-github-owner/groundpath-client

FRONTEND_URL=https://groundpath.one

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=groundpath
MYSQL_USER=groundpath
MYSQL_PASSWORD=change-me-app-password

JWT_SECRET=change-me-jwt-secret-at-least-32-chars
ENCRYPTION_KEY=change-me-encryption-key-at-least-32-chars
EMAIL_VERIFICATION_SECRET=change-me-email-verification-secret

EMBEDDING_PROVIDER=zhipu
ZHIPU_API_KEY=change-me-zhipu-api-key

# Optional outbound proxy.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,mysql,redis,qdrant,server,client,hy2-client
NODE_USE_ENV_PROXY=

# Set true only when deploy/hysteria/client.yaml exists on the server.
ENABLE_HYSTERIA_PROXY=false

# Blue/green runtime ports. OpenResty should proxy to one of them.
BLUE_CLIENT_PORT=18081
GREEN_CLIENT_PORT=18082
CLIENT_HOST_BIND=127.0.0.1

# Deploy script behavior.
HEALTHCHECK_TIMEOUT_SECONDS=180
OLD_STACK_DRAIN_TIMEOUT_SECONDS=300
OPENRESTY_INCLUDE_PATH=/www/sites/groundpath.one/proxy/groundpath-active.inc
OPENRESTY_RELOAD_COMMAND='openresty -s reload'

# Reserved keys. Do not define these manually:
# DEPLOY_SHARED_ENV_FILE
# DEPLOY_IMAGE_TAG
# SERVER_IMAGE
# CLIENT_IMAGE
# CLIENT_PORT
