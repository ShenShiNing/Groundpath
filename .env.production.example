# Groundpath production template for 1Panel + OpenResty
# Usage:
#   1. Copy to `.env.production`
#   2. Replace every CHANGE_ME value
#   3. Run `docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build`

# ==================== Public Entry Point ====================
# OpenResty should reverse proxy groundpath.one to 127.0.0.1:${CLIENT_PORT}
CLIENT_PORT=18080
FRONTEND_URL=https://groundpath.one
TRUST_PROXY=1

# ==================== Database ====================
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root_password
MYSQL_DATABASE=groundpath
MYSQL_USER=groundpath
MYSQL_PASSWORD=CHANGE_ME_mysql_app_password
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_TIMEZONE=+00:00

# ==================== Server ====================
SERVER_TIMEOUT=30000
SERVER_KEEP_ALIVE_TIMEOUT=65000
SHUTDOWN_TIMEOUT=10000
REDIS_PREFIX=groundpath
LOG_LEVEL=info

# ==================== Authentication ====================
# Must be at least 32 characters
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars
JWT_ISSUER=groundpath
JWT_AUDIENCE=groundpath-client
ENCRYPTION_KEY=CHANGE_ME_encryption_key_at_least_32_chars
OAUTH_EXCHANGE_CODE_SECRET=
EMAIL_VERIFICATION_SECRET=CHANGE_ME_email_verification_secret
# If you enable OAuth and observe callback/session issues, try `lax`
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_DOMAIN=

# ==================== Email / SMTP ====================
# Optional at startup, but recommended for production if email verification is enabled
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Groundpath
EMAIL_FROM_ADDRESS=noreply@groundpath.one

# ==================== OAuth (Optional) ====================
# If you enable GitHub / Google login, callbacks must point to groundpath.one
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://groundpath.one/api/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://groundpath.one/api/auth/oauth/google/callback

# ==================== Storage ====================
# First launch can use local storage. After object storage is ready, switch to r2.
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/data/uploads

# Uncomment when switching to Cloudflare R2
# STORAGE_TYPE=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://files.groundpath.one
# FILE_SIGNING_SECRET=CHANGE_ME_file_signing_secret_at_least_32_chars

DISABLE_FILE_SIGNING=false

# ==================== Embedding Provider ====================
# Choose exactly one provider and fill the matching key
EMBEDDING_PROVIDER=zhipu
EMBEDDING_CONCURRENCY=5
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# For self-hosted Ollama on the host machine
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==================== Vector Database ====================
QDRANT_API_KEY=

# ==================== LLM / Agent Optional ====================
MODEL_FETCH_TIMEOUT=15000
TAVILY_API_KEY=

# ==================== VLM Optional ====================
IMAGE_DESCRIPTION_ENABLED=false
VLM_PROVIDER=openai
VLM_MODEL=gpt-4o-mini
VLM_API_KEY=
VLM_BASE_URL=

# ==================== Queue / Scheduler ====================
QUEUE_CONCURRENCY=3
DOCUMENT_PROCESSING_RECOVERY_CRON=*/10 * * * *
DOCUMENT_BUILD_CLEANUP_CRON=30 3 * * *
DOCUMENT_BUILD_CLEANUP_RETENTION_DAYS=7
DOCUMENT_BUILD_CLEANUP_BATCH_SIZE=100
BACKFILL_SCHEDULE_CRON=0 2 * * *

# ==================== Structured RAG / Feature Flags ====================
STRUCTURED_RAG_ENABLED=false
STRUCTURED_RAG_ROLLOUT_MODE=disabled
STRUCTURED_RAG_INTERNAL_USER_IDS=
STRUCTURED_RAG_INTERNAL_KB_IDS=
STRUCTURED_RAG_ALERTS_ENABLED=false
STRUCTURED_RAG_ALERT_EMAIL_TO=
STRUCTURED_RAG_ALERT_SCHEDULE_CRON=0 5 * * *
DISABLE_RATE_LIMIT=false
COUNTER_SYNC_ENABLED=false
DOCUMENT_PROCESSING_RECOVERY_ENABLED=true
DOCUMENT_PROCESSING_RECOVERY_REQUEUE_ENABLED=true
DOCUMENT_BUILD_CLEANUP_ENABLED=true
LOG_CLEANUP_ENABLED=true
BACKFILL_SCHEDULE_ENABLED=false
