# Copy this file to `.env` before running `pnpm docker:up`.
# Required values must be filled with non-empty secrets.

# ==================== Public Entry Points ====================
CLIENT_PORT=8080
SERVER_PORT=3000

# ==================== Local-Only Debug Ports ====================
# These ports are published to 127.0.0.1 only by docker-compose.yml.
MYSQL_PORT=3306
REDIS_PORT=6379
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ==================== Database ====================
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=knowledge_agent
MYSQL_USER=knowledge_agent
MYSQL_PASSWORD=

# ==================== Server ====================
TRUST_PROXY=1
FRONTEND_URL=http://localhost:8080
JWT_SECRET=
ENCRYPTION_KEY=
EMAIL_VERIFICATION_SECRET=
REDIS_PREFIX=groundpath
LOG_LEVEL=info

# ==================== Storage ====================
STORAGE_TYPE=local
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
# FILE_SIGNING_SECRET=

# ==================== Embedding Providers ====================
# Choose one provider and fill the matching credentials.
EMBEDDING_PROVIDER=zhipu
ZHIPU_API_KEY=
# ZHIPU_EMBEDDING_MODEL=embedding-3
# ZHIPU_EMBEDDING_DIMENSIONS=1024
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==================== VLM (Optional) ====================
IMAGE_DESCRIPTION_ENABLED=false
# VLM_PROVIDER=openai
# VLM_MODEL=gpt-4o-mini
# VLM_API_KEY=
# VLM_BASE_URL=

# ==================== Other Optional Features ====================
# TAVILY_API_KEY=
# STRUCTURED_RAG_ENABLED=false
# STRUCTURED_RAG_ROLLOUT_MODE=disabled
