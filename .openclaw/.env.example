# OpenClaw Multi-Agent Team - API Keys
# Copy this file to .env and fill in your actual API keys

# Relay A - Claude models (OpenAI-compatible proxy)
RELAY_CLAUDE_BASE_URL=https://your-relay.example.com/v1
RELAY_CLAUDE_API_KEY=sk-your-relay-claude-key

# Relay B - Code models: DeepSeek / Codex (OpenAI-compatible proxy)
RELAY_CODE_BASE_URL=https://your-relay2.example.com/v1
RELAY_CODE_API_KEY=sk-your-relay-code-key

# Direct Anthropic API (optional, if not using relay for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
